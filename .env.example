# Self-hosted Supabase configuration.
#
# Point these at the Supabase instance running on your VPS (or local
# `supabase start`). Do NOT commit a real anon key for a non-public
# instance — copy this file to `.env` (which is gitignored) and fill in
# your values there.
#
# Local CLI default (`supabase start` on the same machine):
#   VITE_SUPABASE_URL=http://127.0.0.1:54321
#
# VPS-hosted Supabase (Kong gateway is on :8000 by default):
#   VITE_SUPABASE_URL=http://your-vps-host:8000
#   # or with a domain + reverse proxy:
#   VITE_SUPABASE_URL=https://supabase.example.com

VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_PUBLISHABLE_KEY=your-self-hosted-anon-key
VITE_SUPABASE_PROJECT_ID=local

# Optional: where the in-app "Open in Supabase Studio" admin links should
# go. Defaults to port 3000 of the host in VITE_SUPABASE_URL, which is
# the standard self-host docker-compose layout (Studio on :3000, API on
# :8000). Override if your Studio lives somewhere else.
# VITE_SUPABASE_STUDIO_URL=http://localhost:3000
